# Copy to .env and fill in your values.
# docker-compose picks this up automatically.

# ── FPP connection ─────────────────────────────────────────────────────────
FPP_HOST=192.168.200.10         # Pi 5 running Falcon Player (try .10, alt .11)
FPP_PORT=80                     # FPP web UI / REST API port (default 80)
FPP_TIMEOUT=5                   # seconds before giving up on FPP call

# ── FPP overlay model names (must match exactly what you set in FPP UI) ────
FPP_PHOTO_MODEL=PhotoZone       # pixel overlay covering rows 0-139 (192×140)
FPP_TICKER_MODEL=TickerZone     # pixel overlay covering rows 140-191 (192×52)

# ── FPP playlist name ──────────────────────────────────────────────────────
FPP_BASE_PLAYLIST=breaking_news # playlist that runs the base background animation

# ── Flask ─────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string

# ── Upload limits ─────────────────────────────────────────────────────────
UPLOAD_MAX_BYTES=5242880        # 5 MB
